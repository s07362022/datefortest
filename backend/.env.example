# ─── 資料庫 ───────────────────────────────────────────
# Docker PostgreSQL（本機開發用）
DATABASE_URL=postgresql://postgres:devpassword123@localhost:5432/datingapp

# PostgreSQL 密碼（與 docker-compose.yml 一致）
POSTGRES_PASSWORD=devpassword123

# ─── JWT ──────────────────────────────────────────────
# 用 openssl rand -hex 32 產生，正式環境請換成長隨機字串
SECRET_KEY=change_this_to_a_long_random_secret_key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─── App ──────────────────────────────────────────────
APP_ENV=development
# development | staging | production

# ─── 照片儲存（開發初期用本機路徑） ────────────────────
UPLOAD_DIR=uploads

# ─── 管理員 ───────────────────────────────────────────
# 初始管理員帳號（seed data 用）
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_this_admin_password
